project_id = "your-project-id"
region     = "region from available regions list"

service_name = "a name for your service"
artifact_repo = "a name for your artifact repository"

kms_key_resource_name = "projects/PROJECT_ID/locations/LOCATION/keyRings/KEY_RING_NAME/cryptoKeys/CRYPTO_KEY_NAME"

# Leave blank for the first apply (this provisions everything except Cloud Run + API Gateway)
image = ""

github_app_id         = "123456"

# Optional: e.g. "pull_request,push"
github_accepted_events = ""

# Secrets are managed in Secret Manager (not in Terraform variables/state).
# After your first `terraform apply`, add secret values with gcloud, e.g.:
#   echo -n "<webhook-secret>" | gcloud secrets versions add github-webhook-secret --data-file=-
#   gcloud secrets versions add github-private-key --data-file=/path/to/private-key.pem
